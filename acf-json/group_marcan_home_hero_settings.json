{
  "key": "group_marcan_home_hero_settings",
  "title": "Hero de inicio",
  "fields": [
    {
      "key": "field_marcan_hero_mobile_copy",
      "label": "Texto móvil",
      "name": "hero_mobile_copy",
      "type": "textarea",
      "rows": 4,
      "new_lines": "wpautop"
    },
    {
      "key": "field_marcan_hero_autoplay",
      "label": "Autoplay",
      "name": "hero_autoplay",
      "type": "true_false",
      "ui": 1,
      "default_value": 1
    },
    {
      "key": "field_marcan_hero_interval",
      "label": "Intervalo",
      "name": "hero_interval",
      "type": "number",
      "default_value": 5000,
      "min": 1000,
      "step": 500
    },
    {
      "key": "field_marcan_hero_effect",
      "label": "Efecto",
      "name": "hero_effect",
      "type": "select",
      "choices": {
        "fade": "Fade",
        "zoom": "Zoom"
      },
      "default_value": "fade",
      "return_format": "value"
    }
  ],
  "location": [
    [
      {
        "param": "page_type",
        "operator": "==",
        "value": "front_page"
      }
    ]
  ],
  "active": true
}
