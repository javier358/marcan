{
    "key": "group_marcan_home_page",
    "title": "Inicio - Contenido",
    "fields": [
        {
            "key": "field_marcan_tab_home_hero",
            "label": "1. Hero",
            "name": "",
            "type": "tab",
            "placement": "top",
            "endpoint": 0
        },
        {
            "key": "field_marcan_hero_autoplay",
            "label": "Autoplay",
            "name": "hero_autoplay",
            "type": "true_false",
            "ui": 1,
            "default_value": 1,
            "instructions": "Reproducir el slider automaticamente."
        },
        {
            "key": "field_marcan_hero_interval",
            "label": "Intervalo",
            "name": "hero_interval",
            "type": "number",
            "default_value": 5000,
            "min": 1000,
            "step": 500,
            "instructions": "Milisegundos entre slides (1000 = 1 segundo)."
        },
        {
            "key": "field_marcan_hero_effect",
            "label": "Efecto",
            "name": "hero_effect",
            "type": "select",
            "choices": {
                "fade": "Fade",
                "zoom": "Zoom"
            },
            "default_value": "fade",
            "return_format": "value"
        },
        {
            "key": "field_marcan_home_hero_slides",
            "label": "Slides del hero",
            "name": "hero_slides",
            "type": "repeater",
            "layout": "row",
            "button_label": "Agregar slide",
            "sub_fields": [
                {
                    "key": "field_marcan_home_slide_hero_imgs",
                    "label": "Imagenes del slide",
                    "name": "hero_imagenes",
                    "type": "repeater",
                    "layout": "table",
                    "button_label": "Agregar imagen",
                    "instructions": "Sube una imagen por cada tamano de pantalla. Cada fila indica la medida exacta, el peso maximo y el formato recomendados. Si dejas un tamano sin imagen, se usa la del tamano mas cercano disponible. Formato recomendado: WEBP (tambien PNG/JPG).",
                    "max": 6,
                    "sub_fields": [
                        {
                            "key": "field_marcan_home_slide_hero_img_device",
                            "label": "Pantalla",
                            "name": "dispositivo",
                            "type": "select",
                            "return_format": "value",
                            "allow_null": 0,
                            "default_value": "desktop",
                            "choices": {
                                "mobile_portrait": "Movil vertical · 480x854 px · max 350 KB",
                                "mobile_landscape": "Movil horizontal · 854x480 px · max 350 KB",
                                "tablet": "Tablet · 1024x768 px · max 400 KB",
                                "laptop": "Laptop · 1366x854 px · max 450 KB",
                                "desktop": "Desktop · 1920x1246 px · max 550 KB",
                                "desktop_xl": "Monitor grande · 2560x1440 px · max 650 KB"
                            }
                        },
                        {
                            "key": "field_marcan_home_slide_hero_img_file",
                            "label": "Imagen",
                            "name": "imagen",
                            "type": "image",
                            "return_format": "id",
                            "preview_size": "thumbnail",
                            "library": "all",
                            "instructions": "Formato recomendado: WEBP. Tambien PNG o JPG."
                        }
                    ]
                },
                {
                    "key": "field_marcan_home_hero_slide_label",
                    "label": "Etiqueta",
                    "name": "etiqueta",
                    "type": "text"
                },
