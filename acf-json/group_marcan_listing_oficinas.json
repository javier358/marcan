                        "mobile_landscape": "Movil horizontal · 854x480 px · max 350 KB",
                        "tablet": "Tablet · 1024x768 px · max 400 KB",
                        "laptop": "Laptop · 1366x854 px · max 450 KB",
                        "desktop": "Desktop · 1920x1246 px · max 550 KB",
                        "desktop_xl": "Monitor grande · 2560x1440 px · max 650 KB"
                    }
                },
                {
                    "key": "field_marcan_ofi_hero_hero_img_file",
                    "label": "Imagen",
                    "name": "imagen",
                    "type": "image",
                    "return_format": "id",
                    "preview_size": "thumbnail",
                    "library": "all",
                    "instructions": "Formato recomendado: WEBP. Tambien PNG o JPG."
